<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#1F1F1F"
    app:cardCornerRadius="16dp"
    app:strokeColor="#2C2C2C"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Иконка медали (слева) -->
        <ImageView
            android:id="@+id/iv_achievement_medal"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_test_result"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="Медаль за достижение" />

        <!-- Информационный блок: заголовок и описание -->
        <!-- Название ачивки -->
        <TextView
            android:id="@+id/tv_achievement_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp"
            android:text="Название достижения"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/iv_achievement_medal"
            app:layout_constraintEnd_toStartOf="@id/card_xp_badge"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Описание ачивки -->
        <TextView
            android:id="@+id/tv_achievement_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="12dp"
            android:text="Подробное описание условий для получения медали."
            android:textColor="#B3B3B3"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.1"
            app:layout_constraintStart_toStartOf="@id/tv_achievement_title"
            app:layout_constraintEnd_toStartOf="@id/card_xp_badge"
            app:layout_constraintTop_toBottomOf="@id/tv_achievement_title"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Премиальный бейдж награды (XP) на базе компактного MaterialCardView -->
        <!-- Это исключает необходимость создавать отдельный drawable для закругленного фона -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_xp_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#2A1B40"
            app:cardCornerRadius="8dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tv_achievement_xp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+100 XP"
                android:textColor="#BB86FC"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp" />

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>


</com.google.android.material.card.MaterialCardView>