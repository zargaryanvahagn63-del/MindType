<?xml version="1.0" encoding="UTF-8" ?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 1. ЗАГОЛОВОК СЕКЦИИ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="8dp"
            android:text="ЦЕНТР ИССЛЕДОВАНИЙ"
            android:textColor="#BB86FC"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <!-- 2. БЛОК ЦИТАТЫ ДНЯ (DAILY QUOTE CARD) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="4dp"
            app:cardBackgroundColor="#1F1F1F"
            app:cardCornerRadius="20dp"
            app:strokeColor="#2C2C2C"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <ImageView
                    android:id="@+id/iv_quote_decor"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_quote"
                    app:tint="#33BB86FC"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tvQuoteText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Загрузка мудрых мыслей..."
                    android:textColor="#E0E0E0"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-light"
                    android:lineSpacingMultiplier="1.3"
                    android:textStyle="italic"
                    app:layout_constraintTop_toBottomOf="@id/iv_quote_decor" />

                <TextView
                    android:id="@+id/tvQuoteAuthor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text=""
                    android:textColor="#BB86FC"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/tvQuoteText"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3. СЕКЦИЯ ЕЖЕДНЕВНЫХ КВЕСТОВ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginStart="8dp"
            android:text="ТЕКУЩИЕ ЗАДАНИЯ"
            android:textColor="#666666"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDailyTasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false" />

        <!-- 4. СЕКЦИЯ СИСТЕМЫ ДОСТИЖЕНИЙ (МЕДАЛИ) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginStart="8dp"
            android:text="МЕДАЛИ И ДОСТИЖЕНИЯ"
            android:textColor="#666666"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAchievements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>


</androidx.core.widget.NestedScrollView>